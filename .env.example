# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me

# Public-facing site URL — used by Supabase Auth as the redirect target for
# email confirmation, magic links, and password resets. Falls back to
# window.location.origin in the browser if unset, but Vercel must have it.
# Local: http://localhost:3000   Production: https://www.passtheplate.store
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic API key for the Shushu chat widget (/api/chat). Without this,
# the widget returns a generic "trouble connecting" 500. Get one at
# https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-replace_me

# Mapbox public access token for the Listing Hotspots map on /sell.
# Without this the section renders a "Map unavailable" fallback instead
# of the interactive map. Public token (NEXT_PUBLIC_) is fine — Mapbox
# tokens are designed to be exposed in the browser. Get one at
# https://account.mapbox.com/access-tokens/. Restrict the token to the
# production hostnames in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.replace_me

# Resend (transactional email) — powers the team notification emails sent
# after every successful inquiry / contact form / newsletter signup. If any
# of these three are unset, src/lib/notify.ts logs a warning and skips the
# send (forms still write to the DB), so dev / CI environments don't need
# real values. Get an API key at https://resend.com/.
#   NOTIFY_FROM_EMAIL must be on a verified Resend domain.
#   NOTIFY_TO_EMAIL is the team inbox that receives every notification.
RESEND_API_KEY=re_replace_me
NOTIFY_FROM_EMAIL=notifications@passtheplate.store
NOTIFY_TO_EMAIL=team@passtheplate.store
